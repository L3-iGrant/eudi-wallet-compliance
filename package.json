{
  "name": "eudi-wallet-compliance",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "lint:no-em-dashes": "! grep -rn --exclude-dir=node_modules --exclude-dir=.next --exclude-dir=out --exclude-dir=dist --include=\"*.ts\" --include=\"*.tsx\" --include=\"*.md\" --include=\"*.yaml\" --include=\"*.yml\" --include=\"*.json\" \"—\" apps packages tools README.md 2>/dev/null",
    "lint": "pnpm -r lint && pnpm lint:no-em-dashes"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "pagefind": "^1.5.2"
  }
}
